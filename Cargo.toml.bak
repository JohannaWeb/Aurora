
[package]
name = "aurora"
version = "0.1.0"
edition = "2024"

[dependencies]
rustls = { version = "0.23", features = ["ring"] } # still needed for install_crypto_provider()
wgpu = "23.0"
winit = "0.30.5"
vello = "0.7.0"
pollster = "0.3"
flate2 = "1.0"
boa_engine = "0.19"
boa_gc = "0.19"
opus = { path = "../Opus" }
ab_glyph = "0.2"
ttf-parser = "0.21"
rustybuzz = "0.18"
peniko = "0.6"
image = "0.24"
anyhow = "1.0"
html5ever = "0.27"
markup5ever = "0.12"
cssparser = "0.31"
selectors = "0.25"
taffy = "0.5"
parley = "0.1"
reqwest = { version = "0.12", features = ["blocking", "rustls-tls", "gzip", "deflate", "brotli"], default-features = false }
